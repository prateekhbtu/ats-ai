# ─── ATS AI Frontend Environment ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Backend API URL — your Cloudflare Workers deployment
# For local development: http://localhost:8787
VITE_API_BASE=https://ats-ai.workspace-infoga.workers.dev

# Google OAuth Client ID
# Get it from: https://console.cloud.google.com/apis/credentials
# Must match the GOOGLE_CLIENT_ID secret set in your CF Worker.
# Authorised JavaScript origins must include your frontend URL.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Verbose API logging in DevTools (true | false)
# Set to true during development; set to false for production builds.
VITE_ENABLE_LOGS=true
